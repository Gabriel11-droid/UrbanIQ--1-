# Configurações do servidor
PORT=3001
NODE_ENV=development

# CORS — origens permitidas, separadas por vírgula
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://127.0.0.1:3000

# Chave de API para autenticação (só vale em NODE_ENV=production)
URBANIQ_API_KEY=sk_live_dev_change_me

# Rate limiting — requests por minuto por IP
RATE_LIMIT_PER_MIN=240
